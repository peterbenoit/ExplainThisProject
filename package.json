{
	"name": "explain-this-project",
	"displayName": "Explain This Project",
	"description": "Analyzes your project structure and generates a comprehensive PROJECT_OVERVIEW.md file with details about languages, frameworks, dependencies, and architecture.",
	"version": "0.3.0",
	"icon": "icon.png",
	"publisher": "peterbenoit",
	"author": {
		"name": "Peter Benoit",
		"email": "peterbenoit@gmail.com"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/peterbenoit/explain-this-project.git"
	},
	"bugs": {
		"url": "https://github.com/peterbenoit/explain-this-project/issues"
	},
	"homepage": "https://www.peterbenoit.com/vscode/",
	"keywords": [
		"project",
		"analysis",
		"documentation",
		"overview",
		"markdown",
		"dependencies",
		"architecture"
	],
	"engines": {
		"vscode": "^1.105.0"
	},
	"categories": [
		"Other",
		"Programming Languages"
	],
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"commands": [
			{
				"command": "explain-this-project.explainProject",
				"title": "Explain This Project",
				"category": "Project Analysis"
			},
			{
				"command": "explain-this-project.explainProjectForceOverwrite",
				"title": "Explain This Project (Force Overwrite)",
				"category": "Project Analysis"
			},
			{
				"command": "explain-this-project.askQuestions",
				"title": "Explain This Project: Ask Questions",
				"category": "Project Analysis"
			}
		],
		"configuration": {
			"title": "Explain This Project",
			"properties": {
				"explainThisProject.includeDevDependencies": {
					"type": "boolean",
					"default": true,
					"description": "Include development dependencies in the analysis"
				},
				"explainThisProject.maxDirectoryDepth": {
					"type": "number",
					"default": 3,
					"minimum": 1,
					"maximum": 10,
					"description": "Maximum directory depth to analyze"
				},
				"explainThisProject.excludeDirectories": {
					"type": "array",
					"default": [
						"node_modules",
						".git",
						"dist",
						"build",
						"coverage"
					],
					"description": "Directories to exclude from analysis"
				},
				"explainThisProject.openaiApiKey": {
					"type": "string",
					"default": "",
					"description": "OpenAI API key for the project explanation agent",
					"markdownDescription": "Your OpenAI API key. Get one at [OpenAI Platform](https://platform.openai.com/api-keys)"
				},
				"explainThisProject.aiSummaryTimeoutSeconds": {
					"type": "number",
					"default": 30,
					"minimum": 5,
					"maximum": 120,
					"description": "Maximum seconds to wait for the AI summary before skipping it and writing the file anyway"
				},
				"explainThisProject.llmProvider": {
					"type": "string",
					"enum": [
						"copilot",
						"openai"
					],
					"enumDescriptions": [
						"Use GitHub Copilot (free tier supported, no API key required)",
						"Use OpenAI directly (requires API key)"
					],
					"default": "copilot",
					"description": "LLM provider to use for the Ask Questions agent"
				},
				"explainThisProject.includeGitAnalysis": {
					"type": "boolean",
					"default": true,
					"description": "Include git history analysis (churn hotspots, contributors, commit trends) in the overview"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && node esbuild.js",
		"check-types": "tsc --noEmit",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && node esbuild.js --production",
		"install-extension": "vsce package && code --install-extension $(ls explain-this-project-*.vsix | sort -V | tail -1)",
		"install-extension-win": "vsce package && node -e \"const fs=require('fs');const f=fs.readdirSync('.').filter(x=>x.endsWith('.vsix')).sort().pop();require('child_process').execSync('code --install-extension '+f,{stdio:'inherit'})\"",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"dependencies": {
		"openai": "^4.67.0"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/vscode": "^1.105.0",
		"@typescript-eslint/eslint-plugin": "^8.45.0",
		"@typescript-eslint/parser": "^8.45.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.0",
		"eslint": "^9.36.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"diff": "^8.0.4",
		"serialize-javascript": "^7.0.5"
	}
}
